<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="16dp" android:gravity="center_horizontal">
    
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Ví Bitcoin Mainnet" android:textSize="24sp" android:textStyle="bold"/>
    
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Địa chỉ bc1q:" android:layout_marginTop="16dp"/>
    
    <TextView android:id="@+id/addressText" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="Chưa có ví"
        android:textIsSelectable="true" android:padding="10dp" android:background="#333"
        android:textColor="#FFF"/>
    
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Số dư:" android:layout_marginTop="12dp"/>
    
    <TextView android:id="@+id/balanceText" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="0 BTC" android:textSize="20sp"/>
    
    <!-- HIỂN THỊ GIÁ BTC/USD -->
    <TextView android:id="@+id/priceText" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="BTC: $0" android:textSize="14sp"/>
    
    <Button android:id="@+id/newAddressBtn" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="Tạo địa chỉ mới" android:layout_marginTop="16dp"/>
    <Button android:id="@+id/receiveBtn" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="Nhận (QR)"/>
    <Button android:id="@+id/sendBtn" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="Gửi"/>
    <Button android:id="@+id/manageBtn" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="Quản lý ví"/>
    <Button android:id="@+id/seedBtn" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="Xuất Seed"/>
    
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Lịch sử giao dịch:" android:layout_marginTop="12dp" android:textStyle="bold"/>
    
    <!-- LIST LỊCH SỬ -->
    <ListView android:id="@+id/historyList" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1" android:background="#111"/>
</LinearLayout>