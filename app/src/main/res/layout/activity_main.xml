<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="16dp">

    <TextView android:id="@+id/priceText" android:text="BTC: $0" android:textSize="20sp" android:textStyle="bold" android:textColor="#000000" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/balanceText" android:text="0 BTC" android:textSize="26sp" android:textColor="#000000" android:layout_marginTop="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/addressText" android:text="address" android:textColor="#000000" android:textIsSelectable="true" android:layout_marginTop="8dp" android:layout_width="match_parent" android:layout_height="wrap_content"/>

    <Button android:id="@+id/receiveBtn" android:text="Nhận" android:layout_marginTop="20dp" android:layout_width="match_parent" android:layout_height="wrap_content"/>
    <Button android:id="@+id/sendBtn" android:text="Gửi" android:layout_width="match_parent" android:layout_height="wrap_content"/>
    <Button android:id="@+id/manageBtn" android:text="Quản lý ví" android:layout_width="match_parent" android:layout_height="wrap_content"/>
    <Button android:id="@+id/seedBtn" android:text="Seed" android:layout_width="match_parent" android:layout_height="wrap_content"/>

    <ListView android:id="@+id/historyList" android:layout_marginTop="16dp" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
</LinearLayout>